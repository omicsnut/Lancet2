<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Lancet2 CPU Profile Report</title>
<style>
  :root {
    --bg: #1a1b26; --surface: #24283b; --border: #3b4261;
    --text: #c0caf5; --text-dim: #565f89; --accent: #7aa2f7;
    --red: #f7768e; --green: #9ece6a; --yellow: #e0af68;
    --magenta: #bb9af7; --cyan: #7dcfff;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'JetBrains Mono', 'Fira Code', 'Menlo', monospace;
    background: var(--bg); color: var(--text);
    line-height: 1.6; padding: 2rem; max-width: 1400px; margin: 0 auto;
  }
  h1 { color: var(--accent); font-size: 1.8rem; margin-bottom: 0.5rem; }
  h2 {
    color: var(--cyan); font-size: 1.2rem; margin: 2rem 0 0.5rem;
    border-bottom: 1px solid var(--border); padding-bottom: 0.3rem;
  }
  .meta { color: var(--text-dim); font-size: 0.85rem; margin-bottom: 2rem; }
  .stat-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem; margin: 1rem 0;
  }
  .stat-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 8px; padding: 1rem;
  }
  .stat-card .label { color: var(--text-dim); font-size: 0.75rem; text-transform: uppercase; }
  .stat-card .value { color: var(--accent); font-size: 1.4rem; font-weight: bold; }
  table {
    width: 100%; border-collapse: collapse; margin: 1rem 0;
    background: var(--surface); border-radius: 8px; overflow: hidden;
  }
  th {
    background: var(--border); color: var(--cyan); text-align: left;
    padding: 0.6rem 0.8rem; font-size: 0.8rem; cursor: pointer;
    user-select: none;
  }
  th:hover { background: #4b5577; }
  td { padding: 0.4rem 0.8rem; border-bottom: 1px solid var(--border); font-size: 0.85rem; }
  tr:hover td { background: rgba(122, 162, 247, 0.05); }
  .bar-cell { width: 200px; }
  .bar {
    height: 14px; border-radius: 3px;
    background: linear-gradient(90deg, var(--accent), var(--cyan));
  }
  .bar-red { background: linear-gradient(90deg, var(--red), #ff9e64); }
  .bar-green { background: linear-gradient(90deg, var(--green), #73daca); }
  .bar-magenta { background: linear-gradient(90deg, var(--magenta), #c0a8e0); }
  .bar-yellow { background: linear-gradient(90deg, var(--yellow), #ffd080); }
  .bar-dim { background: var(--border); }
  details { margin: 0.5rem 0; }
  summary {
    cursor: pointer; color: var(--cyan); font-weight: bold;
    padding: 0.5rem; background: var(--surface); border-radius: 4px;
  }
  summary:hover { background: var(--border); }
  .svg-container {
    overflow: auto; margin: 1rem 0; background: var(--surface);
    border: 1px solid var(--border); border-radius: 8px; padding: 1rem;
    position: relative;
  }
  .svg-container svg { height: auto; transition: transform 0.2s; transform-origin: top left; }
  .zoom-controls {
    display: flex; gap: 0.5rem; margin-bottom: 0.5rem;
  }
  .zoom-controls button {
    background: var(--surface); border: 1px solid var(--border); color: var(--accent);
    padding: 0.3rem 0.8rem; border-radius: 4px; cursor: pointer; font-size: 0.9rem;
    font-family: inherit;
  }
  .zoom-controls button:hover { background: var(--border); }
  .zoom-controls span { color: var(--text-dim); font-size: 0.8rem; line-height: 2; }
  .footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--text-dim); font-size: 0.75rem; }
  .pct-red { color: var(--red); }
  .pct-yellow { color: var(--yellow); }
  .pct-green { color: var(--green); }
  .pct-dim { color: var(--text-dim); }
</style>
</head>
<body>

<h1>🔬 Lancet2 CPU Profile Report</h1>
<div class="meta">
  Generated {{ report.timestamp }} · Version {{ report.version.full }}
</div>

{# ── Overview ────────────────────────────────────────────────────────────── #}
<h2>📊 Overview</h2>
<div class="stat-grid">
  <div class="stat-card">
    <div class="label">Total CPU Time</div>
    <div class="value">{{ "%.1f"|format(report.meta.total_min) }} min</div>
  </div>
  <div class="stat-card">
    <div class="label">Binary</div>
    <div class="value" style="font-size: 0.9rem;">{{ report.meta.binary }}</div>
  </div>
  <div class="stat-card">
    <div class="label">Profile Type</div>
    <div class="value" style="font-size: 0.9rem;">{{ report.meta.profile_type }}</div>
  </div>
  <div class="stat-card">
    <div class="label">Functions Shown</div>
    <div class="value">{{ report.meta.shown_nodes }} / {{ report.meta.total_nodes }}</div>
  </div>
</div>

{# ── Component Breakdown ─────────────────────────────────────────────────── #}
<h2>🧩 Component Breakdown</h2>
<table>
  <thead>
    <tr><th onclick="sortTable(this, 0)">Component</th><th onclick="sortTable(this, 1)">Self (s)</th>
    <th onclick="sortTable(this, 2)">Self %</th><th>Bar</th></tr>
  </thead>
  <tbody>
  {% for comp in report.components %}
    <tr>
      <td>{{ comp.name }}</td>
      <td>{{ "%.2f"|format(comp.sec) }}s</td>
      <td class="{% if comp.pct >= 10 %}pct-red{% elif comp.pct >= 5 %}pct-yellow{% elif comp.pct >= 1 %}pct-green{% else %}pct-dim{% endif %}">{{ "%.1f"|format(comp.pct) }}%</td>
      <td class="bar-cell"><div class="bar{% if 'minimap2' in comp.name %} bar-red{% elif 'Lancet2' in comp.name %} bar-magenta{% elif 'HTSlib' in comp.name %} bar-green{% elif 'SPOA' in comp.name %} bar-yellow{% elif comp.pct < 2 %} bar-dim{% endif %}" style="width: {{ (comp.pct * 2)|int }}%"></div></td>
    </tr>
    {% for sub in comp.subs %}
    <tr>
      <td style="padding-left: 2rem; color: var(--text-dim);">└─ {{ sub.name }}</td>
      <td style="color: var(--text-dim);">{{ "%.2f"|format(sub.sec) }}s</td>
      <td class="pct-dim">{{ "%.1f"|format(sub.pct) }}%</td>
      <td></td>
    </tr>
    {% endfor %}
  {% endfor %}
  </tbody>
</table>

{# ── Top Functions ────────────────────────────────────────────────────────── #}
<h2>🔥 Top Functions by Self-Time</h2>
<table id="functions-table">
  <thead>
    <tr>
      <th onclick="sortTable(this, 0)">#</th>
      <th onclick="sortTable(this, 1)">Function</th>
      <th onclick="sortTable(this, 2)">Self (s)</th>
      <th onclick="sortTable(this, 3)">Self %</th>
      <th onclick="sortTable(this, 4)">Cum (s)</th>
      <th onclick="sortTable(this, 5)">Cum %</th>
      <th>Bar</th>
    </tr>
  </thead>
  <tbody>
  {% for fn in report.functions %}
    <tr>
      <td>{{ loop.index }}</td>
      <td>{{ fn.name }}</td>
      <td>{{ "%.2f"|format(fn.flat_sec) }}s</td>
      <td class="{% if fn.flat_pct >= 5 %}pct-red{% elif fn.flat_pct >= 2 %}pct-yellow{% elif fn.flat_pct >= 0.5 %}pct-green{% else %}pct-dim{% endif %}">{{ "%.1f"|format(fn.flat_pct) }}%</td>
      <td>{{ "%.2f"|format(fn.cum_sec) }}s</td>
      <td>{{ "%.1f"|format(fn.cum_pct) }}%</td>
      <td class="bar-cell"><div class="bar{% if fn.flat_pct >= 5 %} bar-red{% elif fn.flat_pct >= 2 %} bar-yellow{% elif fn.flat_pct < 0.5 %} bar-dim{% endif %}" style="width: {{ (fn.flat_pct * 5)|int }}%"></div></td>
    </tr>
  {% endfor %}
  </tbody>
</table>

{# ── Call Graph SVG ──────────────────────────────────────────────────────── #}
{% if report.callgraph_svg %}
<h2>🌳 Call Graph</h2>
<details open>
  <summary>Call Graph (SVG) — use controls to zoom and scroll</summary>
  <div class="zoom-controls">
    <button onclick="zoomSvg(-0.25)">➖ Zoom Out</button>
    <button onclick="zoomSvg(0.25)">➕ Zoom In</button>
    <button onclick="resetZoom()">↺ Reset</button>
    <button onclick="fitZoom()">⊞ Fit</button>
    <span id="zoom-level">100%</span>
  </div>
  <div class="svg-container" id="svg-viewport">
    {{ report.callgraph_svg | safe }}
  </div>
</details>
{% endif %}

<div class="footer">
  Lancet2 Profile Analysis · {{ report.version.full }} · {{ report.timestamp }}
</div>

<script>
function sortTable(th, colIdx) {
  const table = th.closest('table');
  const tbody = table.querySelector('tbody');
  const rows = Array.from(tbody.querySelectorAll('tr'));
  const asc = th.dataset.sort !== 'asc';
  th.dataset.sort = asc ? 'asc' : 'desc';

  rows.sort((a, b) => {
    let aVal = a.cells[colIdx]?.textContent.trim() || '';
    let bVal = b.cells[colIdx]?.textContent.trim() || '';
    const aNum = parseFloat(aVal);
    const bNum = parseFloat(bVal);
    if (!isNaN(aNum) && !isNaN(bNum)) {
      return asc ? aNum - bNum : bNum - aNum;
    }
    return asc ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
  });

  rows.forEach(row => tbody.appendChild(row));
}

// SVG zoom controls
let currentZoom = 1.0;
function applyZoom() {
  const svg = document.querySelector('#svg-viewport svg');
  if (!svg) return;
  svg.style.transform = `scale(${currentZoom})`;
  svg.style.transformOrigin = 'top left';
  document.getElementById('zoom-level').textContent = Math.round(currentZoom * 100) + '%';
}
function zoomSvg(delta) {
  currentZoom = Math.max(0.25, Math.min(5.0, currentZoom + delta));
  applyZoom();
}
function resetZoom() {
  currentZoom = 1.0;
  applyZoom();
}
function fitZoom() {
  const container = document.getElementById('svg-viewport');
  const svg = document.querySelector('#svg-viewport svg');
  if (!svg || !container) return;
  // Reset to get natural size
  svg.style.transform = 'none';
  const ratio = container.clientWidth / svg.getBoundingClientRect().width;
  currentZoom = Math.min(2.0, Math.max(0.25, ratio));
  applyZoom();
}

// Mouse wheel zoom
const viewport = document.getElementById('svg-viewport');
if (viewport) {
  viewport.addEventListener('wheel', function(e) {
    if (e.ctrlKey || e.metaKey) {
      e.preventDefault();
      zoomSvg(e.deltaY < 0 ? 0.1 : -0.1);
    }
  }, {passive: false});
}
</script>

</body>
</html>
